# ============================
# Google Sheets Configuration
# ============================
# Path ke file credentials JSON dari Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# ID Spreadsheet (dari URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Nama sheet/tab yang ingin di-sync
SHEET_NAME=Sheet1

# ============================
# Trello Configuration
# ============================
# API Key dari https://trello.com/power-ups/admin
TRELLO_API_KEY=e36e165cf92ea5bf7111169c599ebf0e

# Token dari https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key={YOUR_API_KEY}
TRELLO_TOKEN=ATTA1e38e74687ebe3e6d7b0b91964e5d559af2e16571ebc497d229f7b616b66f87890E99669

# Board ID (jalankan: python manual_sync.py --list-boards)
TRELLO_BOARD_ID=your_board_id_here

# List ID tempat card dibuat (jalankan: python manual_sync.py --list-lists)
TRELLO_LIST_ID=your_list_id_here

# ============================
# Webhook Configuration
# ============================
# Secret key untuk validasi webhook (opsional, buat sendiri)
WEBHOOK_SECRET=your_webhook_secret_here

# Port untuk webhook server
WEBHOOK_PORT=5000
